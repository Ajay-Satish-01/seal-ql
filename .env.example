# ============================================================
# Database
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=intelligence_connector
POSTGRES_PORT=5432

# Full DATABASE_URL — override this if you change the credentials above
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intelligence_connector
DUCKDB_PATH=:memory:

# ============================================================
# LLM Configuration (Ollama is the default — no API key needed)
# To disable Ollama from starting in docker-compose, set OLLAMA_PROFILE=disabled
# ============================================================
# LLM_MODEL=ollama/llama3.2:3b
# LLM_BASE_URL=http://ollama:11434

# Optional: Override with cloud LLM providers
# LLM_TYPE=cloud
# LLM_MODEL=gemini/gemini-1.5-flash
# GEMINI_API_KEY=AIzaSy...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_API_KEY=sk-... # Generic fallback key if provider-specific key isn't set
# LLM_BASE_URL=https://api.openai.com/v1

# ============================================================
# Query Safety — Sanitizer
# ============================================================
MAX_ROWS=10000
MAX_JOINS=10
MAX_SUBQUERY_DEPTH=5

# ============================================================
# Query Safety — Executor
# ============================================================
QUERY_TIMEOUT_SECONDS=30
QUERY_MAX_RETRIES=2
QUERY_ROW_CAP=10000
QUERY_RETRY_BASE_DELAY=0.5

# ============================================================
# LLM Retry
# ============================================================
LLM_MAX_RETRIES=2

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================================
# Ports (host-side)
# ============================================================
API_PORT=8000
OLLAMA_PORT=11434
