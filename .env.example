# ============================================================
# Database
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=intelligence_connector
POSTGRES_PORT=5432

# Full DATABASE_URL — override this if you change the credentials above
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intelligence_connector
DUCKDB_PATH=:memory:

# ============================================================
# LLM Configuration (Ollama is the default — no API key needed)
# ============================================================
LLM_MODEL=ollama/llama3.2:3b
LLM_BASE_URL=http://ollama:11434

# Optional: Override with cloud LLM providers
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1

# ============================================================
# Query Safety
# ============================================================
MAX_ROWS=10000
QUERY_TIMEOUT_SECONDS=30

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================================
# Ports (host-side)
# ============================================================
API_PORT=8000
OLLAMA_PORT=11434
