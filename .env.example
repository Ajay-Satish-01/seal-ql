# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/intelligence_connector
DUCKDB_PATH=:memory:

# LLM Configuration (Ollama is default — no API key needed)
LLM_MODEL=ollama/llama3.1
LLM_BASE_URL=http://ollama:11434

# Optional: Override with cloud LLM providers
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1

# Query Safety
MAX_ROWS=10000
QUERY_TIMEOUT_SECONDS=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
