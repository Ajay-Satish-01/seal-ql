# ============================================================
# Database
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=intelligence_connector
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intelligence_connector
DUCKDB_PATH=:memory:

# ============================================================
# LLM (LiteLLM) — see https://docs.litellm.ai/docs/providers
#
# LLM_MODEL uses LiteLLM provider/model ids, e.g.:
#   ollama/llama3.2:1b
#   gemini/gemini-1.5-flash
#   openai/gpt-4o-mini
#   anthropic/claude-3-5-sonnet-20241022
#
# OLLAMA_PROFILE:
#   default (or omit) → local Ollama + LLM_BASE_URL
#   disabled          → cloud model + API key (no Ollama container)
# ============================================================

# --- Local Ollama (default) ---
# LLM_MODEL=ollama/llama3.2:1b
# LLM_BASE_URL=http://ollama:11434

# --- Cloud (example: Gemini) ---
# OLLAMA_PROFILE=disabled
# LLM_MODEL=gemini/gemini-1.5-flash
# LLM_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here

# ============================================================
# Query Safety — Sanitizer
# ============================================================
MAX_ROWS=10000
MAX_JOINS=10
MAX_SUBQUERY_DEPTH=5

# ============================================================
# Query Safety — Executor
# ============================================================
QUERY_TIMEOUT_SECONDS=30
QUERY_MAX_RETRIES=2
QUERY_ROW_CAP=10000
QUERY_RETRY_BASE_DELAY=0.5

# ============================================================
# LLM Retry
# ============================================================
LLM_MAX_RETRIES=2

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================================
# Ports (host-side)
# ============================================================
API_PORT=8000
OLLAMA_PORT=11434

# Compose: make up sets COMPOSE_PROFILES=default when using local Ollama
# COMPOSE_PROFILES=default
