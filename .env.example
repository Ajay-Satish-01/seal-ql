# ============================================================
# Database
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=seal
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/seal
DUCKDB_PATH=:memory:

# ============================================================
# LLM (LiteLLM) — see https://docs.litellm.ai/docs/providers
#
# LLM_MODEL uses LiteLLM provider/model ids, e.g.:
#   ollama/llama3.2:1b
#   gemini/gemini-2.0-flash
#   openai/gpt-4o-mini
#   anthropic/claude-3-5-sonnet-20241022
#
# OLLAMA_PROFILE:
#   default (or omit) → local Ollama + LLM_BASE_URL
#   disabled          → cloud model + API key (no Ollama container)
# ============================================================

# --- Local Ollama (default) ---
# OLLAMA_PROFILE=default
# LLM_MODEL=ollama/llama3.2:1b
# LLM_BASE_URL=http://ollama:11434

# --- Cloud (example: Gemini) ---
# OLLAMA_PROFILE=disabled
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=your-key-here
# GEMINI_API_KEY=your-key-here
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

LLM_MAX_RETRIES=2

# ============================================================
# Query Safety — Sanitizer
# ============================================================
MAX_ROWS=10000
MAX_JOINS=10
MAX_SUBQUERY_DEPTH=5

# ============================================================
# Query Safety — Executor
# ============================================================
QUERY_TIMEOUT_SECONDS=30
QUERY_MAX_RETRIES=2
QUERY_ROW_CAP=10000
QUERY_RETRY_BASE_DELAY=0.5

# ============================================================
# API authentication (FastAPI APIKeyHeader — X-API-Key)
# ============================================================
# When SEAL_API_KEY is set, /v1/* requires header: X-API-Key: <key>
# Generate for production: openssl rand -hex 32
# Local dev only (not allowed when SEAL_AUTH_REQUIRED=true):
SEAL_API_KEY=dev-local-change-me
SEAL_AUTH_REQUIRED=false
SEAL_DEV_MODE=true
SEAL_DISABLE_DOCS=false

# ============================================================
# Data catalog (global — /v1/query and /v1/chat)
# Docker: use /app/config/catalog.yaml or rely on compose default
# ============================================================
DATA_CATALOG_PATH=config/catalog.yaml
CATALOG_AUTO_SYNC=true
CATALOG_PRUNE_REMOVED=true
DATA_CATALOG_STRICT=false

# ============================================================
# Chat / prompt enhancement
# ============================================================
CHAT_ENHANCEMENT_ENABLED=true
CHAT_SESSION_TTL_SECONDS=3600
CHAT_MAX_HISTORY_MESSAGES=20
CHAT_SUMMARIZE_AFTER_MESSAGES=12
CHAT_RECENT_MESSAGES=6
CHAT_MAX_CONTEXT_TABLES=8
# SEAL_ENHANCERS=your.module.CustomEnhancer

# ============================================================
# Vector RAG
# ============================================================
VECTOR_STORE=none
# VECTOR_STORE=chroma
# When using chroma, rebuild API with chromadb (make up sets SEAL_EXTRA if unset):
# SEAL_EXTRA=chroma
CHROMA_PERSIST_PATH=/app/data/chroma
EMBEDDING_MODEL=text-embedding-3-small
# RAG_DOCUMENTS_PATH=
RAG_TOP_K=5
RAG_MAX_CONTEXT_TOKENS=1500
RAG_EMBED_BATCH_SIZE=32
RAG_EMBED_MAX_CONCURRENT=4
# VECTOR_STORE_CLASS=
# VECTOR_STORE_CONFIG=

# ============================================================
# Semantic layer (optional YAML metrics)
# ============================================================
# SEMANTIC_DIRECTORY=

# ============================================================
# CORS & ports
# ============================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
API_PORT=8000
OLLAMA_PORT=11434

# Compose: make up sets COMPOSE_PROFILES=default when using local Ollama
# COMPOSE_PROFILES=default

# Docker build only (not read by Settings) — see docs/integrations/vector-stores.md
# SEAL_EXTRA=chroma
