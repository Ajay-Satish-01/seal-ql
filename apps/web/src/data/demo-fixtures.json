    {
      "id": "revenue-by-category",
      "label": "Revenue by category",
      "query": "Show total revenue by product category",
      "response": {
        "sql": "SELECT p.category, SUM(o.amount) AS total_revenue FROM orders o JOIN products p ON o.product_id = p.id WHERE o.status = 'completed' GROUP BY p.category ORDER BY total_revenue DESC LIMIT 10000",
        "columns": [
          {
            "name": "category",
            "type": "varchar",
            "nullable": true
          },
          {
            "name": "total_revenue",
            "type": "numeric",
            "nullable": true
          }
        ],
        "results": [
          {
